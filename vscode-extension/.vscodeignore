# Files to exclude from extension package
.vscode/**
.vscode-test/**
node_modules/**
src/**
.gitignore
.yarnrc
vsc-extension-quickstart.md
**/tsconfig.json
**/.eslintrc.json
**/*.map
**/*.ts
!out/**/*.js
docs/**
scripts/**
resources/skills/**
tests/**
.pytest_cache/**

# Exclude AI agent skill folders (not needed in extension)
.agent/**
.claude/**
.codex/**
.cursor/**
.gemini/**
.github/**
.opencode/**
.roo/**
.trae/**
.windsurf/**
.skillsrc

# Keep walkthrough resources
!resources/**
!resources/repo-assets/**
!resources/repo-assets/**/.github/**
!resources/repo-assets/**/.claude/**
!resources/repo-assets/**/.cline/**
!resources/repo-assets/**/.clinerules/**
!resources/repo-assets/**/scripts/**
