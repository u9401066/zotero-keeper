# =============================================================================
# Zotero Keeper - Environment Configuration
# =============================================================================
# Copy this file to .env and modify according to your setup.

# -----------------------------------------------------------------------------
# Zotero Connection Settings
# -----------------------------------------------------------------------------

# Zotero machine IP or hostname (localhost if on same machine)
ZOTERO_HOST=localhost

# Zotero HTTP server port (default: 23119)
ZOTERO_PORT=23119

# Request timeout in seconds
ZOTERO_TIMEOUT=30

# -----------------------------------------------------------------------------
# PubMed Integration (Optional)
# -----------------------------------------------------------------------------

# Your email for NCBI/PubMed API
NCBI_EMAIL=your.email@example.com

# NCBI API key (optional)
# NCBI_API_KEY=your_api_key_here

# Optional: re-enable legacy keeper PubMed bridge/import tools
# ZOTERO_KEEPER_ENABLE_LEGACY_PUBMED_TOOLS=1

# Optional: local development override for pubmed-search-mcp source checkout
# PUBMED_SEARCH_PATH=../external/pubmed-search-mcp
