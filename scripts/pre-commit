#!/usr/bin/env bash
# =============================================================================
# Git Pre-Commit Hook — Production-Grade Quality Gate
# =============================================================================
# Runs: TypeScript compile + lint + test (VSX), Python ruff + pytest (MCP)
# Install: scripts/install-hooks.sh or manually:
#   cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# =============================================================================

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "╔══════════════════════════════════════╗"
echo "║  Pre-Commit Quality Gate             ║"
echo "╚══════════════════════════════════════╝"

FAILED=0

# ─── VSCode Extension Checks ─────────────────────────────────────────

# Check if any VSX files are staged
VSX_CHANGED=$(git diff --cached --name-only -- 'vscode-extension/' | wc -l)

if [ "$VSX_CHANGED" -gt 0 ]; then
    echo ""
    echo -e "${YELLOW}▶ VSCode Extension checks...${NC}"

    pushd vscode-extension > /dev/null

    # 1. TypeScript compile
    echo -n "  [1/3] TypeScript compile... "
    if npx tsc -p ./ --noEmit 2>/dev/null; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo "    Run: cd vscode-extension && npx tsc -p ./ --noEmit"
        FAILED=1
    fi

    # 2. ESLint
    echo -n "  [2/3] ESLint... "
    if npm run lint 2>/dev/null 1>/dev/null; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo "    Run: cd vscode-extension && npm run lint"
        FAILED=1
    fi

    # 3. Unit tests
    echo -n "  [3/3] Unit tests... "
    if npm test 2>/dev/null 1>/dev/null; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo "    Run: cd vscode-extension && npm test"
        FAILED=1
    fi

    popd > /dev/null
else
    echo -e "\n${YELLOW}▶ VSCode Extension: no changes, skipping${NC}"
fi

# ─── MCP Server Checks ───────────────────────────────────────────────

MCP_CHANGED=$(git diff --cached --name-only -- 'mcp-server/' | wc -l)

if [ "$MCP_CHANGED" -gt 0 ]; then
    echo ""
    echo -e "${YELLOW}▶ MCP Server checks...${NC}"

    pushd mcp-server > /dev/null

    # 1. Ruff lint
    echo -n "  [1/3] Ruff lint... "
    if uv run ruff check src/ 2>/dev/null 1>/dev/null; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo "    Run: cd mcp-server && uv run ruff check src/"
        FAILED=1
    fi

    # 2. Ruff format check
    echo -n "  [2/3] Ruff format... "
    if uv run ruff format --check src/ 2>/dev/null 1>/dev/null; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo "    Run: cd mcp-server && uv run ruff format src/"
        FAILED=1
    fi

    # 3. Pytest (unit tests only, skip integration tests requiring Zotero)
    echo -n "  [3/3] Unit tests... "
    if uv run pytest tests/unit/ -q 2>/dev/null 1>/dev/null; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗${NC}"
        echo "    Run: cd mcp-server && uv run pytest tests/unit/ -v"
        FAILED=1
    fi

    popd > /dev/null
else
    echo -e "\n${YELLOW}▶ MCP Server: no changes, skipping${NC}"
fi

# ─── General Checks ──────────────────────────────────────────────────

echo ""
echo -e "${YELLOW}▶ General checks...${NC}"

# Check for trailing whitespace in staged files
echo -n "  [1/2] Trailing whitespace... "
if git diff --cached --check 2>/dev/null; then
    echo -e "${GREEN}✓${NC}"
else
    echo -e "${RED}✗${NC}"
    echo "    Fix trailing whitespace in staged files"
    FAILED=1
fi

# Check for merge conflict markers
echo -n "  [2/2] Merge conflict markers... "
CONFLICT_FILES=$(git diff --cached --name-only | xargs grep -l '^<<<<<<< \|^=======$\|^>>>>>>> ' 2>/dev/null || true)
if [ -z "$CONFLICT_FILES" ]; then
    echo -e "${GREEN}✓${NC}"
else
    echo -e "${RED}✗${NC}"
    echo "    Conflict markers found in: $CONFLICT_FILES"
    FAILED=1
fi

# ─── Result ───────────────────────────────────────────────────────────

echo ""
if [ "$FAILED" -eq 0 ]; then
    echo -e "${GREEN}╔══════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║  ✓ All checks passed!                ║${NC}"
    echo -e "${GREEN}╚══════════════════════════════════════╝${NC}"
    exit 0
else
    echo -e "${RED}╔══════════════════════════════════════╗${NC}"
    echo -e "${RED}║  ✗ Pre-commit checks failed!         ║${NC}"
    echo -e "${RED}║  Fix the issues above, then retry.   ║${NC}"
    echo -e "${RED}╚══════════════════════════════════════╝${NC}"
    exit 1
fi
